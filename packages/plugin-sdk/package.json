{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@palimpsest/plugin-sdk",
  "version": "1.2.22",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build:types": "tsc -p tsconfig.types.json --pretty false",
    "build": "tsc"
  },
  "exports": {
    ".": "./src/index.ts",
    "./tool": "./src/tool.ts",
    "./product": "./src/product.ts",
    "./workflow": "./src/workflow.ts",
    "./host": "./src/host.ts",
    "./host-web": "./src/host-web.ts"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@palimpsest/sdk": "workspace:*",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "hono": "catalog:",
    "solid-js": "catalog:"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@typescript/native-preview": "catalog:"
  }
}
