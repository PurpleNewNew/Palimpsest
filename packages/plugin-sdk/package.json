{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@palimpsest/plugin-sdk",
  "version": "1.2.22",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build:types": "tsc -p tsconfig.types.json --pretty false",
    "build": "tsc"
  },
  "exports": {
    ".": "./src/index.ts",
    "./tool": "./src/tool.ts",
    "./product": "./src/product.ts",
    "./workflow": "./src/workflow.ts",
    "./host": "./src/host.ts",
    "./host-web": "./src/host-web.ts",
    "./web/graph-workbench": "./src/web/graph-workbench.tsx",
    "./web/object-workspace-fullscreen": "./src/web/object-workspace-fullscreen.tsx",
    "./web/file-inspector": "./src/web/file-inspector.tsx",
    "./web/session-chat-panel": "./src/web/session-chat-panel.tsx",
    "./web/chat/session-id": "./src/web/chat/session-id.tsx",
    "./web/chat/handoff": "./src/web/chat/handoff.ts",
    "./web/chat/history-window": "./src/web/chat/history-window.ts",
    "./web/chat/timeline-staging": "./src/web/chat/timeline-staging.ts"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@palimpsest/sdk": "workspace:*",
    "@palimpsest/shared": "workspace:*",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@antv/g6": "5.0.51",
    "@solidjs/router": "catalog:",
    "hono": "catalog:",
    "solid-js": "catalog:"
  },
  "peerDependenciesMeta": {
    "@antv/g6": {
      "optional": true
    },
    "@solidjs/router": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@antv/g6": "5.0.51",
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@typescript/native-preview": "catalog:"
  }
}
