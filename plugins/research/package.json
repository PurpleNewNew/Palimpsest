{
  "name": "@palimpsest/plugin-research",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:dep-types": "bun ../script/build-dep-types.ts",
    "build:web-types": "bun run build:dep-types && tsc -p tsconfig.web.json --pretty false",
    "typecheck:web": "bun run build:web-types",
    "typecheck:server": "bun run build:dep-types && tsc -p tsconfig.server.json --pretty false",
    "typecheck": "bun run typecheck:web && bun run typecheck:server"
  },
  "exports": {
    ".": "./plugin.ts",
    "./plugin": "./plugin.ts",
    "./manifest": "./manifest.ts",
    "./server": "./server/index.ts",
    "./server/research-schema": "./server/research-schema.ts",
    "./server/host-bridge": "./server/host-bridge.ts",
    "./server/experiment-execution-watch": "./server/experiment-execution-watch.ts",
    "./server/experiment-remote-task": "./server/experiment-remote-task.ts",
    "./server/experiment-remote-task-watcher": "./server/experiment-remote-task-watcher.ts",
    "./server/experiment-watcher": "./server/experiment-watcher.ts",
    "./server/experiment-guard": "./server/experiment-guard.ts",
    "./server/research": "./server/research.ts",
    "./server/routes": "./server/routes.ts",
    "./server/tools/atom-graph-prompt/builder": "./server/tools/atom-graph-prompt/builder.ts",
    "./server/tools/atom-graph-prompt/community": "./server/tools/atom-graph-prompt/community.ts",
    "./server/tools/atom-graph-prompt/embedding": "./server/tools/atom-graph-prompt/embedding.ts",
    "./server/tools/atom-graph-prompt/hybrid": "./server/tools/atom-graph-prompt/hybrid.ts",
    "./server/tools/atom-graph-prompt/scoring": "./server/tools/atom-graph-prompt/scoring.ts",
    "./server/tools/atom-graph-prompt/token-budget": "./server/tools/atom-graph-prompt/token-budget.ts",
    "./server/tools/atom-graph-prompt/traversal": "./server/tools/atom-graph-prompt/traversal.ts",
    "./server/tools/atom-graph-prompt/types": "./server/tools/atom-graph-prompt/types.ts",
    "./server/tools/experiment-remote-task": "./server/tools/experiment-remote-task.ts",
    "./web": {
      "types": "./types/web/index.d.ts",
      "default": "./web/index.ts"
    },
    "./web/context/research": {
      "types": "./types/web/context/research.d.ts",
      "default": "./web/context/research.ts"
    },
    "./web/prompt-actions": {
      "types": "./types/web/prompt-actions.d.ts",
      "default": "./web/prompt-actions.ts"
    },
    "./web/pages/research": {
      "types": "./types/web/pages/research.d.ts",
      "default": "./web/pages/research.tsx"
    },
    "./web/pages/literature": {
      "types": "./types/web/pages/literature.d.ts",
      "default": "./web/pages/literature.tsx"
    },
    "./web/components/atom-graph-view": {
      "types": "./types/web/components/atom-graph-view.d.ts",
      "default": "./web/components/atom-graph-view.tsx"
    },
    "./web/components/research-taxonomy": {
      "types": "./types/web/components/research-taxonomy.d.ts",
      "default": "./web/components/research-taxonomy.ts"
    },
    "./web/research-sdk": {
      "types": "./types/web/research-sdk.d.ts",
      "default": "./web/research-sdk.ts"
    },
    "./web/components/atom-detail-node": {
      "types": "./types/web/components/atom-detail-node.d.ts",
      "default": "./web/components/atom-detail-node.tsx"
    },
    "./web/components/atom-detail-view": {
      "types": "./types/web/components/atom-detail-view.d.ts",
      "default": "./web/components/atom-detail-view.tsx"
    }
  },
  "dependencies": {
    "@dagrejs/dagre": "3.0.0",
    "@dschz/solid-flow": "0.1.4",
    "@palimpsest/plugin-sdk": "workspace:*",
    "@palimpsest/runner": "workspace:*",
    "@palimpsest/sdk": "workspace:*",
    "@palimpsest/ui": "workspace:*",
    "@solidjs/router": "catalog:",
    "@zip.js/zip.js": "2.7.62",
    "diff": "catalog:",
    "drizzle-orm": "catalog:",
    "graphology": "0.26.0",
    "graphology-communities-louvain": "2.0.2",
    "hono": "catalog:",
    "hono-openapi": "catalog:",
    "solid-js": "catalog:",
    "unzipper": "0.12.3",
    "zod": "catalog:"
  }
}
