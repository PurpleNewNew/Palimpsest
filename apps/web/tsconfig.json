{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowJs": true,
    "resolveJsonModule": true,
    "strict": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "outDir": "node_modules/.ts-dist",
    "isolatedModules": true,
    "paths": {
      "@/*": ["./src/*"],
      "@palimpsest/plugin-core": ["../../plugins/core/plugin.ts"],
      "@palimpsest/plugin-research": ["../../plugins/research/plugin.ts"],
      "@palimpsest/plugin-research/web/pages/*": [
        "../../plugins/research/web/pages/*"
      ],
      "@palimpsest/plugin-research/web/context/*": [
        "../../plugins/research/web/context/*"
      ],
      "@palimpsest/plugin-research/web/prompt-actions": [
        "../../plugins/research/web/prompt-actions.ts"
      ],
      "@palimpsest/plugin-security-audit": ["../../plugins/security-audit/plugin.ts"],
      "@palimpsest/plugin-security-audit/web/pages/*": [
        "../../plugins/security-audit/web/pages/*"
      ],
      "@palimpsest/plugin-security-audit/web/context/*": [
        "../../plugins/security-audit/web/context/*"
      ]
    }
  },
  "include": [
    "src",
    "package.json",
    "../../plugins/research/web/**/*.ts",
    "../../plugins/research/web/**/*.tsx",
    "../../plugins/security-audit/web/**/*.ts",
    "../../plugins/security-audit/web/**/*.tsx"
  ],
  "exclude": ["dist", "ts-dist"]
}
