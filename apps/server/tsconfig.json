{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tsconfig/bun/tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "@opentui/solid",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": [],
    "noUncheckedIndexedAccess": false,
    "customConditions": ["browser"],
    "paths": {
      "@/*": ["./src/*"],
      "@tui/*": ["./src/cli/cmd/tui/*"],
      "@palimpsest/plugin-core": ["../../plugins/core/plugin.ts"],
      "@palimpsest/plugin-research": ["../../plugins/research/plugin.ts"],
      "@palimpsest/plugin-security-audit": ["../../plugins/security-audit/plugin.ts"]
    }
  }
}
