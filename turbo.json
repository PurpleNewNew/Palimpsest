{
  "$schema": "https://v2-8-13.turborepo.dev/schema.json",
  "globalEnv": ["CI", "PALIMPSEST_DISABLE_SHARE"],
  "globalPassThroughEnv": ["CI", "PALIMPSEST_DISABLE_SHARE"],
  "tasks": {
    "typecheck": {},
    "build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "@palimpsest/server#test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@palimpsest/web#test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
